{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/dayfold/**",
              "ui_kits/deck/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color - use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value - use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Hanken Grotesk|Anton|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Hanken Grotesk, Anton, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|color|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:clay|rose|ochre|olive|sage|steel|sky|lavender|stone)$/]",
        "message": "<Avatar> color must be one of 'clay' | 'rose' | 'ochre' | 'olive' | 'sage' | 'steel' | 'sky' | 'lavender' | 'stone'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|color|variant|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, color, variant, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:clay|rose|ochre|sand|olive|sage|steel|sky|lavender|stone)$/]",
        "message": "<Badge> color must be one of 'clay' | 'rose' | 'ochre' | 'sand' | 'olive' | 'sage' | 'steel' | 'sky' | 'lavender' | 'stone'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|outline|solid|dot)$/]",
        "message": "<Badge> variant must be one of 'soft' | 'outline' | 'solid' | 'dot'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|iconLeft|iconRight|fullWidth|disabled|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, iconLeft, iconRight, fullWidth, disabled, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|quiet)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'quiet'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|title|icon|action|tone|padding|radius|style|bodyStyle|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, title, icon, action, tone, padding, radius, style, bodyStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:cream|paper|inverse)$/]",
        "message": "<Card> tone must be one of 'cream' | 'paper' | 'inverse'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|strikethrough|disabled|size|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, label, strikethrough, disabled, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DateChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:weekday|date|selected|dimmed|onClick|style|key|ref|className|style|children)$/]",
        "message": "<DateChip> doesn't accept that prop. Declared props: weekday, date, selected, dimmed, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='HabitBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|color|state|progress|size|onClick|style|key|ref|className|style|children)$/]",
        "message": "<HabitBubble> doesn't accept that prop. Declared props: icon, label, color, state, progress, size, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='HabitBubble'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:sky|sage|olive|ochre|rose|lavender|steel|clay|stone)$/]",
        "message": "<HabitBubble> color must be one of 'sky' | 'sage' | 'olive' | 'ochre' | 'rose' | 'lavender' | 'steel' | 'clay' | 'stone'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HabitBubble'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:default|done|progress)$/]",
        "message": "<HabitBubble> state must be one of 'default' | 'done' | 'progress'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|variant|size|shape|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, variant, size, shape, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|soft|filled|outline)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'soft' | 'filled' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:circle|rounded)$/]",
        "message": "<IconButton> shape must be one of 'circle' | 'rounded'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|type|iconLeft|size|disabled|style|inputStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: value, onChange, placeholder, type, iconLeft, size, disabled, style, inputStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScheduleBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|duration|color|leading|onClick|style|key|ref|className|style|children)$/]",
        "message": "<ScheduleBlock> doesn't accept that prop. Declared props: title, duration, color, leading, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScheduleBlock'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:rose|lavender|steel|sky|sage|olive|ochre|clay|stone)$/]",
        "message": "<ScheduleBlock> color must be one of 'rose' | 'lavender' | 'steel' | 'sky' | 'sage' | 'olive' | 'ochre' | 'clay' | 'stone'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedControl'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|size|style|key|ref|className|style|children)$/]",
        "message": "<SegmentedControl> doesn't accept that prop. Declared props: options, value, onChange, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedControl'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<SegmentedControl> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|disabled|size|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, disabled, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Switch> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TaskRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|checked|onToggle|due|dueColor|meta|style|key|ref|className|style|children)$/]",
        "message": "<TaskRow> doesn't accept that prop. Declared props: title, checked, onToggle, due, dueColor, meta, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TaskRow'] > JSXAttribute[name.name='dueColor'] > Literal[value!=/^(?:rose|ochre|sage|steel|stone)$/]",
        "message": "<TaskRow> dueColor must be one of 'rose' | 'ochre' | 'sage' | 'steel' | 'stone'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
